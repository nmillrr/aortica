# Aortica — environment configuration template
#
# Copy this file to `.env` and adjust values for your deployment:
#
#     cp .env.example .env
#
# Docker Compose (`docker-compose.full.yml`) reads this file automatically.
# `make dev` / `make prod` also load it. Never commit your real `.env`.

# ---------------------------------------------------------------------------
# Compose profile selection
# ---------------------------------------------------------------------------
# `dev`  → API + Vite frontend dev server + docs + edge (default for `make dev`)
# `prod` → API + docs + edge + nginx TLS reverse proxy (used by `make prod`)
COMPOSE_PROFILES=dev

# ---------------------------------------------------------------------------
# Core application
# ---------------------------------------------------------------------------
# Path (inside the container) to a pre-trained model checkpoint. Leave blank to
# run without a model (the API returns quality/uncertainty output only).
# Maps to the model registry / --model CLI option.
AORTICA_MODEL_PATH=

# Secret used to sign JWT session tokens. CHANGE THIS in any real deployment.
# The application reads AORTICA_JWT_SECRET; this alias is provided for clarity.
AORTICA_SECRET_KEY=change-me-to-a-long-random-string
AORTICA_JWT_SECRET=${AORTICA_SECRET_KEY}

# OAuth client credentials for social login (optional).
# The application reads GOOGLE_CLIENT_ID / GITHUB_CLIENT_ID; AORTICA_OAUTH_CLIENT_ID
# is the generic template variable — set the provider-specific ones you use.
AORTICA_OAUTH_CLIENT_ID=
GOOGLE_CLIENT_ID=${AORTICA_OAUTH_CLIENT_ID}
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# URL of the central sync server for edge → cloud result upload (optional).
AORTICA_SYNC_URL=

# Log verbosity: debug | info | warning | error
AORTICA_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Storage locations (inside the container; bind-mounted to ./data, ./logs)
# ---------------------------------------------------------------------------
AORTICA_DATA_DIR=/app/data
AORTICA_LOG_DIR=/app/logs

# ---------------------------------------------------------------------------
# Rate limiting (see aortica/api/rate_limiter.py)
# ---------------------------------------------------------------------------
AORTICA_RATE_LIMIT_ENABLED=true
AORTICA_RATE_LIMIT_DEFAULT_RPM=60
AORTICA_RATE_LIMIT_GLOBAL_RPM=6000
# Optional Redis backend for distributed rate limiting (blank = in-memory).
AORTICA_RATE_LIMIT_REDIS_URL=

# ---------------------------------------------------------------------------
# Host port mapping (override to avoid conflicts on the host)
# ---------------------------------------------------------------------------
AORTICA_API_PORT=8000
AORTICA_FRONTEND_PORT=5173
AORTICA_DOCS_PORT=8001
# HTTPS / HTTP ports exposed by the nginx reverse proxy in `make prod`.
AORTICA_HTTPS_PORT=8443
AORTICA_HTTP_PORT=8080
